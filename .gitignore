# ══════════════════════════════════════════════════
#  StudyMate .gitignore
# ══════════════════════════════════════════════════

# ── 환경변수 (절대 커밋 금지) ──────────────────────
.env
.env.local
.env.*.local

# ── 데이터베이스 ────────────────────────────────────
*.db
*.sqlite
*.sqlite3
server/studymate.db
server/*.db*
# ── 업로드 파일 (디렉토리는 유지) ─────────────────
server/uploads/*
!server/uploads/.gitkeep

# ── 의존성 ──────────────────────────────────────────
node_modules/
.npm/

# ── 빌드 / 캐시 ─────────────────────────────────────
dist/
.cache/
.parcel-cache/

# ── 로그 ────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── 에디터 ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── 테스트 / 커버리지 ────────────────────────────────
coverage/
.nyc_output/

# ── 임시 파일 ───────────────────────────────────────
tmp/
temp/
*.tmp
*.bak